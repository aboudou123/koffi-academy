# Static deployment hardening for public/ root on one.com
# This hardens HTTP headers and disables directory listing.
# It does NOT secure client-side-only admin, auth, payment, or course-lock logic.

# Disable directory browsing
Options -Indexes
ServerSignature Off

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "interest-cohort=()"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
</IfModule>

# Cache control for static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType image/x-icon "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/gif "access plus 1 month"
  ExpiresByType font/woff2 "access plus 1 month"
  ExpiresByType font/woff "access plus 1 month"
  ExpiresByType font/ttf "access plus 1 month"
</IfModule>

# Remove ETag headers for consistent caching behavior
Header unset ETag
FileETag None

# Force UTF-8 for text assets
AddDefaultCharset UTF-8

# Deny access to hidden files and server metadata
<FilesMatch "^\.">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>

# Block pages that require a real backend or expose client-side pseudo-security
<IfModule mod_rewrite.c>
  RewriteEngine On

  # --- Sécurité : blocage de pages sensibles ---
  RewriteRule ^sponsor/?$ pricing.html [L]
  RewriteRule ^sponsor\.html$ pricing.html [L]
  RewriteRule ^admin/ - [F]
  RewriteRule ^payment/(checkout|bank-transfer-request|paypal-success|paypal-cancel)\.html$ - [F]
  RewriteRule ^dashboard\.html$ - [F]
  RewriteRule ^article\.html$ - [F]
  RewriteRule ^contact\.html$ - [F]
  RewriteRule ^paid-courses/ - [F]

  # --- Clean URLs : sert folder/index.html pour /folder ---
  # Si ce n'est pas un fichier existant ET que folder/index.html existe → le servir
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}/index.html -f
  RewriteRule ^(.+?)/?$ /$1/index.html [L]
</IfModule>
