# Static deployment hardening for public/ root on one.com
# This hardens HTTP headers and disables directory listing.
# It does NOT secure client-side-only admin, auth, payment, or course-lock logic.

# Disable directory browsing
Options -Indexes
ServerSignature Off

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "interest-cohort=()"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
  Header always set Cross-Origin-Opener-Policy "same-origin"

  # 2026-06-28: Content-Security-Policy (defense-en-profondeur anti-XSS / injection).
  # NOTE: le site utilise beaucoup de scripts/styles inline + de nombreux CDN, donc
  # 'unsafe-inline' reste necessaire (sinon le site casse). La CSP verrouille malgre
  # tout les vecteurs critiques : object-src (plugins), base-uri (vol de base href),
  # frame-ancestors (clickjacking), form-action. A durcir plus tard en retirant
  # 'unsafe-inline' apres passage aux nonces.
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://www.gstatic.com https://www.paypal.com https://www.paypalobjects.com https://apis.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com https://cdn.jsdelivr.net; font-src 'self' data: https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: blob: https:; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com https://identitytoolkit.googleapis.com https://securetoken.googleapis.com https://firestore.googleapis.com https://www.paypal.com https://api.github.com https://raw.githubusercontent.com; frame-src 'self' https://www.paypal.com https://*.firebaseapp.com https://apis.google.com https://accounts.google.com; object-src 'none'; base-uri 'self'; form-action 'self' https://www.paypal.com; frame-ancestors 'self'; upgrade-insecure-requests"
</IfModule>

# Cache control for static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType image/x-icon "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/gif "access plus 1 month"
  ExpiresByType font/woff2 "access plus 1 month"
  ExpiresByType font/woff "access plus 1 month"
  ExpiresByType font/ttf "access plus 1 month"
</IfModule>

# Remove ETag headers for consistent caching behavior
Header unset ETag
FileETag None

# Force UTF-8 for text assets
AddDefaultCharset UTF-8

# Deny access to hidden files and server metadata
<FilesMatch "^\.">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>

# Block pages that require a real backend or expose client-side pseudo-security
<IfModule mod_rewrite.c>
  RewriteEngine On

  # 2026-06-28: Redirection HTTPS forcee. Tout acces en http:// est redirige en
  # https:// (301). La double condition gere le cas one.com derriere un proxy/CDN
  # qui termine le TLS et transmet X-Forwarded-Proto.
  RewriteCond %{HTTPS} off
  RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  RewriteRule ^admin/ - [F]
  # 2026-06-22: payment/* debloque apres durcissement du prix cote client
  # (prix figes par une table fixe dans checkout.html / bank-transfer-request.html,
  #  le parametre ?price= de l'URL n'est plus utilise). Rebloquer = decommenter.
  # RewriteRule ^payment/(checkout|bank-transfer-request|paypal-success|paypal-cancel)\.html$ - [F]
  RewriteRule ^dashboard\.html$ - [F]
  RewriteRule ^pricing\.html$ - [F]
  # 2026-06-23: login/register debloques sur demande du proprietaire pour
  # permettre l'inscription et la connexion des utilisateurs. Rebloquer = decommenter.
  # RewriteRule ^login\.html$ - [F]
  # RewriteRule ^register\.html$ - [F]
  RewriteRule ^article\.html$ - [F]
  RewriteRule ^contact\.html$ - [F]
  RewriteRule ^free-courses/github-actions\.html$ - [F]
  RewriteRule ^paid-courses/ - [F]

  # 2026-06-23: Anti-hotlink des videos. Le .mp4/.webm n'est servi que si la
  # requete provient de lingenieur.de (lecture sur le site). Acces direct a
  # l'URL et outils de telechargement en ligne -> 403. Compatible avec le
  # Referrer-Policy "strict-origin-when-cross-origin" (le referer same-origin
  # est envoye). Pour autoriser un autre domaine, l'ajouter a la RewriteCond.
  RewriteCond %{HTTP_REFERER} !^https?://(www\.)?lingenieur\.de(/|$) [NC]
  RewriteRule ^assets/videos/.*\.(mp4|webm|m4v|mov)$ - [F,NC]
</IfModule>

# 2026-06-23: Empeche le cache partage de stocker la reponse du .mp4. Sans ca,
# un acces direct sans referer (403) pourrait etre mis en cache puis servi a un
# visiteur legitime, cassant la lecture. no-store => chaque requete repasse par
# la regle anti-hotlink ci-dessus. Vary: Referer en filet de securite.
<IfModule mod_headers.c>
  <FilesMatch "\.(mp4|webm|m4v|mov)$">
    Header always set Cache-Control "no-store, max-age=0"
    Header always set Vary "Referer"
  </FilesMatch>
</IfModule>
