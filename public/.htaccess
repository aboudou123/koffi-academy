# Static deployment hardening for public/ root on one.com
# This hardens HTTP headers and disables directory listing.
# It does NOT secure client-side-only admin, auth, payment, or course-lock logic.

# Disable directory browsing
Options -Indexes
ServerSignature Off

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "interest-cohort=()"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
</IfModule>

# Cache control for static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType image/x-icon "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/gif "access plus 1 month"
  ExpiresByType font/woff2 "access plus 1 month"
  ExpiresByType font/woff "access plus 1 month"
  ExpiresByType font/ttf "access plus 1 month"
</IfModule>

# Remove ETag headers for consistent caching behavior
Header unset ETag
FileETag None

# Force UTF-8 for text assets
AddDefaultCharset UTF-8

# Deny access to hidden files and server metadata
<FilesMatch "^\.">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Block pages that require a real backend (with or without .html)
  RewriteRule ^admin/ - [F,L]
  RewriteRule ^paid-courses/ - [F,L]
  RewriteRule ^payment/(checkout|bank-transfer-request|paypal-success|paypal-cancel)(\.html)?/?$ - [F,L]
  RewriteRule ^(dashboard|article|contact)(\.html)?/?$ - [F,L]

  # Redirect .html URLs → clean URLs (301 permanent)
  RewriteCond %{THE_REQUEST} ^[A-Z]+ /([^?#]*)\.html [NC]
  RewriteRule ^ /%1 [R=301,L,QSA]

  # sponsor alias → /pricing
  RewriteRule ^sponsor/?$ /pricing [R=301,L]

  # Serve .html for any clean URL that has no extension and is not a real file/dir
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^([^.]+)$ $1.html [L]
</IfModule>
